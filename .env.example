# =============================================
# Environment Configuration
# =============================================
# Copy this file to .env and fill in your values

# ---------------------------------------------
# Database (Supabase)
# ---------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# For local PostgreSQL (optional, if not using Supabase)
DATABASE_URL=postgresql://decompritas:decompritas123@localhost:5432/decompritas_store
POSTGRES_USER=decompritas
POSTGRES_PASSWORD=decompritas123
POSTGRES_DB=decompritas_store

# ---------------------------------------------
# Authentication
# ---------------------------------------------
# Secret key for JWT tokens (generate a secure random string)
JWT_SECRET=your-jwt-secret-key-change-in-production

# Default admin password (used for single-tenant mode)
ADMIN_PASSWORD=your-admin-password

# ---------------------------------------------
# Telegram Notifications
# ---------------------------------------------
# Default Telegram configuration (fallback for tenants without custom config)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ---------------------------------------------
# Site Configuration
# ---------------------------------------------
# Public URL of your site
SITE_URL=https://decompritas.com
NEXT_PUBLIC_SITE_URL=https://decompritas.com

# Main domain (without protocol)
MAIN_DOMAIN=decompritas.com

# ---------------------------------------------
# Cron Job Security
# ---------------------------------------------
# Secret key for verifying cron job requests
CRON_SECRET=your-cron-secret-key

# ---------------------------------------------
# PayPal Configuration (Future)
# ---------------------------------------------
# PayPal client credentials for subscription billing
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# ---------------------------------------------
# Redis (Optional)
# ---------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------
# Node Environment
# ---------------------------------------------
NODE_ENV=production